# ══════════════════════════════════════════════════════════════
# Provider Selection — choose your stack
# ══════════════════════════════════════════════════════════════
LLM_PROVIDER=openai                 # openai | ollama | vllm
EMBEDDER_PROVIDER=openai            # openai | bge
BLOB_STORE_PROVIDER=gcs             # gcs | minio
DOC_STORE_PROVIDER=mongo            # mongo
CHUNKER_TYPE=recursive              # recursive | semantic
PARSER_PROVIDER=pypdf               # pypdf | docling
TRACER_PROVIDER=opik                # opik | langfuse | none
NLP_ENRICHMENT=none                 # spacy | none

# ══════════════════════════════════════════════════════════════
# OpenAI (when LLM_PROVIDER=openai or EMBEDDER_PROVIDER=openai)
# ══════════════════════════════════════════════════════════════
OPENAI_API_KEY=change_me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4.1-mini

# ══════════════════════════════════════════════════════════════
# Ollama (when LLM_PROVIDER=ollama) — local, Apple Silicon
# ══════════════════════════════════════════════════════════════
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=mistral

# ══════════════════════════════════════════════════════════════
# vLLM (when LLM_PROVIDER=vllm) — GPU NVIDIA server
# ══════════════════════════════════════════════════════════════
VLLM_URL=http://localhost:8000/v1
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ══════════════════════════════════════════════════════════════
# BGE (when EMBEDDER_PROVIDER=bge) — local embeddings
# ══════════════════════════════════════════════════════════════
BGE_EMBEDDING_MODEL=BAAI/bge-m3

# ══════════════════════════════════════════════════════════════
# Qdrant (vector store)
# ══════════════════════════════════════════════════════════════
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_docs

# ══════════════════════════════════════════════════════════════
# Redis (cache)
# ══════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ══════════════════════════════════════════════════════════════
# MongoDB (when DOC_STORE_PROVIDER=mongo)
# ══════════════════════════════════════════════════════════════
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=rag_ddd
MONGODB_DOCUMENTS_COLLECTION=documents
MONGODB_CHUNKS_COLLECTION=chunks

# ══════════════════════════════════════════════════════════════
# MinIO (when BLOB_STORE_PROVIDER=minio) — self-hosted S3
# ══════════════════════════════════════════════════════════════
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-documents
MINIO_SECURE=false

# ══════════════════════════════════════════════════════════════
# GCS (when BLOB_STORE_PROVIDER=gcs) — Google Cloud Storage
# ══════════════════════════════════════════════════════════════
GCS_BUCKET=rag-ddd-documents

# ══════════════════════════════════════════════════════════════
# NLP enrichment (when NLP_ENRICHMENT=spacy)
# pip install -e ".[nlp]" && python -m spacy download en_core_web_sm
# ══════════════════════════════════════════════════════════════
SPACY_MODEL=en_core_web_sm
NLP_MAX_SUMMARY_SENTENCES=5

# ══════════════════════════════════════════════════════════════
# Chunking and indexing
# ══════════════════════════════════════════════════════════════
CHUNK_SIZE=800
CHUNK_OVERLAP=100
EMBEDDING_BATCH_SIZE=64

# ══════════════════════════════════════════════════════════════
# Retrieval and reranking
# ══════════════════════════════════════════════════════════════
RETRIEVAL_TOP_K=6
RERANK_TOP_K=3
RERANKER_TYPE=cross-encoder         # none | embedding | cross-encoder | bge
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
BGE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu

# ══════════════════════════════════════════════════════════════
# Opik observability (when TRACER_PROVIDER=opik)
# ══════════════════════════════════════════════════════════════
OPIK_ENABLED=true
OPIK_API_KEY=
OPIK_WORKSPACE=
OPIK_PROJECT_NAME=rag-ddd
OPIK_USE_LOCAL=false

# ══════════════════════════════════════════════════════════════
# LangFuse observability (when TRACER_PROVIDER=langfuse)
# ══════════════════════════════════════════════════════════════
LANGFUSE_URL=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=


# ══════════════════════════════════════════════════════════════
# Quick profiles — uncomment one block to switch stack
# ══════════════════════════════════════════════════════════════

# --- Profile: Local secure (sensitive data, on-premise) ---
# LLM_PROVIDER=ollama
# EMBEDDER_PROVIDER=bge
# BLOB_STORE_PROVIDER=minio
# CHUNKER_TYPE=semantic
# PARSER_PROVIDER=docling
# TRACER_PROVIDER=langfuse
# NLP_ENRICHMENT=spacy
# RERANKER_TYPE=bge

# --- Profile: Cloud fast (non-sensitive, quick iteration) ---
# LLM_PROVIDER=openai
# EMBEDDER_PROVIDER=openai
# BLOB_STORE_PROVIDER=gcs
# CHUNKER_TYPE=recursive
# PARSER_PROVIDER=pypdf
# TRACER_PROVIDER=opik
# NLP_ENRICHMENT=none
# RERANKER_TYPE=cross-encoder
